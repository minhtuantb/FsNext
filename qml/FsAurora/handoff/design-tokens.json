  "shadow": {
    "sm": { "value": "0 1px 2px rgba(0,0,0,.04), 0 1px 3px rgba(0,0,0,.06)" },
    "md": { "value": "0 4px 14px rgba(255,91,46,.3)" },
    "lg": { "value": "0 20px 50px -10px rgba(0,0,0,.25), 0 0 0 1px rgba(230,227,220,1)" },
    "xl": { "value": "0 40px 80px -20px rgba(0,0,0,.25), 0 0 0 1px rgba(230,227,220,1)" },
    "focus-ring": { "value": "0 0 0 3px rgba(255,91,46,.22)" }
  },

  "motion": {
