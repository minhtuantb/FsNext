      "exit":       { "value": "cubic-bezier(.4, 0, 1, 1)" }
    }
  },

  "z-index": {
    "sidebar":       { "value": 10 },
    "header":        { "value": 20 },
    "dropdown":      { "value": 100 },
    "modal-overlay": { "value": 200 },
    "modal":         { "value": 210 },
    "toast":         { "value": 300 },
    "tooltip":       { "value": 400 }
