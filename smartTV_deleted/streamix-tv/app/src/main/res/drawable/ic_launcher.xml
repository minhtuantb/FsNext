<!-- StreamIX TV — Composite launcher icon for minSdk 21 fallback.
     Background dark + foreground "S" mark.
     Adaptive icon variant ở mipmap-anydpi-v26/ic_launcher.xml dùng cho API 26+. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F1218" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:drawable="@drawable/ic_launcher_foreground"
        android:gravity="center" />
</layer-list>
