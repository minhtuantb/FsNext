<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme: dark, no ActionBar (Compose-driven UI) -->
    <style name="Theme.StreamIXTV" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/bg_base</item>
        <item name="android:navigationBarColor" tools:targetApi="21">@color/bg_base</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!--
        Splash theme dùng AndroidX SplashScreen compat library (androidx.core:core-splashscreen).
        Attribute `windowSplashScreenBackground` + `postSplashScreenTheme` được backport cho API 21+
        thông qua library — KHÔNG cần Android 12 native API.
    -->
    <style name="Theme.StreamIXTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_base</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.StreamIXTV</item>
    </style>

</resources>
