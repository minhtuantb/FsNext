// SPDX-License-Identifier: Proprietary
// OAuthSecrets.h.example — Template for OAuthSecrets.h
//
// Copy this file to OAuthSecrets.h (which is .gitignored) and fill in
// real client_id / client_secret values from the provider consoles.
// The empty placeholders below let the project compile but every social
// login flow will short-circuit with `configured = false` (because the
// OAuthProvider factories check non-emptiness — see OAuthProvider.h
// google() / facebook() / fptId() factories).
//
// Sources:
//   • Google      : https://console.cloud.google.com/apis/credentials
//                   → OAuth 2.0 Client ID (type "Desktop app")
//   • Facebook    : https://developers.facebook.com/apps/<app-id>/settings/basic/
//                   → App ID + App Secret
//   • FPT ID      : Provided by FTEL SSO team — referenced as `fshare-client`
//                   in "FTEL SSO Integration Guideline v1.5"
//
// CI / release builds: write this file from a secrets-store secret
// (GitHub Actions secret, Vault read, etc.) before CMake configures.

#pragma once
#include <QString>

namespace fsnext::oauth_secrets {

inline const QString kGoogleClientId     = QStringLiteral("");
inline const QString kGoogleClientSecret = QStringLiteral("");

inline const QString kFacebookClientId     = QStringLiteral("");
inline const QString kFacebookClientSecret = QStringLiteral("");

inline const QString kFptIdClientId     = QStringLiteral("");
inline const QString kFptIdClientSecret = QStringLiteral("");

} // namespace fsnext::oauth_secrets
